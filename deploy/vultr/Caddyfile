{
	cert_issuer acme {
		profile shortlived
	}
}

{$DOMAIN} {
	encode zstd gzip

	@assets path /assets/*
	header @assets >Cache-Control "public, max-age=31536000, immutable"

	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	log {
		output stdout
		format console
	}

	reverse_proxy app:3000
}
